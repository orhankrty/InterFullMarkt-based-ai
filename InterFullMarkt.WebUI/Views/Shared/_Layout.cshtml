<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - InterFullMarkt</title>
    
    <!-- Fonts (Removed Inter, using native Arial) -->
    
    <!-- CSS Kütüphaneleri -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        :root {
            --primary-bg: #f8fafc;
            --card-bg: #ffffff;
            --header-bg: #0f172a; /* Gece mavisi / Dark Slate */
            --accent-color: #10b981; /* Canlı Zümrüt Yeşili */
            --text-main: #1e293b;
            --text-secondary: #64748b;
            --text-muted: #94a3b8;
            --gold: #f59e0b;
            --glass: rgba(15, 23, 42, 0.9);
            --border: rgba(0, 0, 0, 0.08);
        }

        body { 
            background-color: var(--primary-bg); 
            color: var(--text-main); 
            font-family: Arial, Helvetica, sans-serif;
            line-height: 1.6;
            font-weight: 400;
            overflow-x: hidden;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        .navbar { 
            background-color: var(--header-bg) !important; 
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding: 1rem 0;
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
        }

        .navbar-brand {
            font-weight: 800;
            letter-spacing: -0.5px;
            font-size: 1.5rem;
            color: #ffffff !important;
        }

        .nav-item {
            margin: 0 0.25rem;
        }

        .nav-link {
            font-weight: 500;
            color: #cbd5e1 !important; /* Açık gri menü metni */
            transition: all 0.2s ease;
            padding: 0.75rem 1.25rem !important;
            border-radius: 8px;
        }

        .nav-link:hover {
            color: var(--accent-color) !important;
            background-color: rgba(255,255,255,0.05);
            transform: translateY(-2px);
        }

        .dropdown-menu {
            background-color: #ffffff;
            border: 1px solid var(--border);
            border-radius: 12px;
            margin-top: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        }

        .dropdown-item {
            color: var(--text-main);
            padding: 0.75rem 1.5rem;
            font-weight: 500;
        }

        .dropdown-item:hover {
            background-color: rgba(16, 185, 129, 0.08);
            color: var(--accent-color);
        }

        /* Global Readability Improvements */
        h1, h2, h3, h4, h5, h6 { 
            color: #0f172a; 
            font-weight: 700; 
            letter-spacing: -0.02em;
        }
        .text-secondary { color: var(--text-secondary) !important; }
        .text-muted { color: var(--text-muted) !important; }
        
        /* Modern Inputs */
        .form-control, .form-select {
            background-color: #ffffff !important;
            border: 1px solid var(--border);
            color: #212529 !important;
            transition: border-color 0.15s ease-in-out, box-shadow 0.15s ease-in-out;
        }
        .form-control:focus, .form-select:focus {
            background-color: #ffffff !important;
            border-color: var(--accent-color);
            box-shadow: 0 0 0 0.25rem rgba(16, 185, 129, 0.15);
            color: #212529 !important;
        }
        .form-control::placeholder {
            color: #6c757d !important;
            opacity: 1 !important;
        }
        
        .card {
            background-color: var(--card-bg);
            border: 1px solid var(--border);
            transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.4s ease;
            box-shadow: 0 8px 15px rgba(0,0,0,0.03);
        }
        
        .card:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 40px rgba(0,0,0,0.08);
        }

        .btn-primary {
            background-color: var(--accent-color);
            border-color: var(--accent-color);
            color: #ffffff;
            font-weight: 600;
        }

        .btn-primary:hover {
            background-color: #059669;
            border-color: #059669;
            color: #ffffff;
        }

        /* Premium Scrollbar */
        ::-webkit-scrollbar { width: 10px; }
        ::-webkit-scrollbar-track { background: var(--primary-bg); }
        ::-webkit-scrollbar-thumb { background: #94a3b8; border-radius: 5px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--text-secondary); }
    </style>
</head>
<body>
    
    <nav class="navbar navbar-expand-lg navbar-dark shadow-lg sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <i class="bi bi-globe-europe-africa fs-3" style="color: var(--accent-color);"></i> InterFullMarkt
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index"><i class="bi bi-house-door"></i> Anasayfa</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Players" asp-action="Index"><i class="bi bi-people"></i> Oyuncular & Takımlar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="News" asp-action="Index"><i class="bi bi-newspaper"></i> Haber Bülteni</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Store" asp-action="Index"><i class="bi bi-cart3"></i> Mağaza</a>
                    </li>
                </ul>
                <ul class="navbar-nav align-items-center">
                    <li class="nav-item me-3">
                        <a href="javascript:void(0)" class="nav-link position-relative px-2" data-bs-toggle="offcanvas" data-bs-target="#cartDrawer">
                            <i class="bi bi-cart3 fs-4"></i>
                            <span id="cartBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">0</span>
                        </a>
                    </li>
                    @if (User.Identity != null && User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle fs-5" style="color: var(--accent-color);"></i> @User.Identity.Name
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="userDropdown">
                                <li><a class="dropdown-item d-flex align-items-center gap-2" asp-controller="Account" asp-action="Index"><i class="bi bi-person-badge text-success"></i> Hesabım</a></li>
                                @if (User.IsInRole("Admin"))
                                {
                                    <li><a class="dropdown-item d-flex align-items-center gap-2" asp-controller="Admin" asp-action="Index"><i class="bi bi-shield-lock text-warning"></i> Admin Paneli</a></li>
                                }
                                <li><a class="dropdown-item d-flex align-items-center gap-2" asp-controller="Dashboard" asp-action="Index"><i class="bi bi-speedometer2 text-info"></i> Kontrol Paneli</a></li>
                                <li><hr class="dropdown-divider border-secondary opacity-25"></li>
                                <li><a class="dropdown-item d-flex align-items-center gap-2 text-danger" asp-controller="Auth" asp-action="Logout"><i class="bi bi-box-arrow-right"></i> Çıkış Yap</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item ms-2">
                            <a class="btn btn-primary px-4 rounded-pill shadow-lg" asp-controller="Auth" asp-action="Login">
                                <i class="bi bi-box-arrow-in-right"></i> Giriş Yap
                            </a>
                        </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main role="main" style="min-height: 85vh;">
        @RenderBody()
    </main>

    <footer class="text-center py-5" style="background-color: var(--header-bg); border-top: 1px solid rgba(255,255,255,0.05);">
        <div class="container">
            <div class="row g-4 align-items-center">
                <div class="col-md-4 text-md-start">
                    <h5 class="mb-3 fw-bold" style="color: #ffffff;">InterFullMarkt</h5>
                    <p class="small" style="color: #94a3b8;">Futbol dünyasının kalbine yolculuk yapın. Oyuncular, kulüpler ve en son haberler burada.</p>
                </div>
                <div class="col-md-4">
                    <div class="d-flex justify-content-center gap-4 fs-4" style="color: #cbd5e1;">
                        <i class="bi bi-twitter-x" style="cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='#cbd5e1'"></i>
                        <i class="bi bi-instagram" style="cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='#cbd5e1'"></i>
                        <i class="bi bi-youtube" style="cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='#cbd5e1'"></i>
                        <i class="bi bi-facebook" style="cursor: pointer; transition: color 0.2s;" onmouseover="this.style.color='#10b981'" onmouseout="this.style.color='#cbd5e1'"></i>
                    </div>
                </div>
                <div class="col-md-4 text-md-end" style="color: #94a3b8;">
                    <p class="mb-0">&copy; @DateTime.Now.Year - InterFullMarkt Platformu</p>
                    <small>Tüm Hakları Saklıdır.</small>
                </div>
            </div>
        </div>
    </footer>

    <partial name="_CartDrawer" />
    <partial name="_AIChatbot" />
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>