@model List<InterFullMarkt.Application.Features.Players.Queries.GetPlayerById.GetPlayerByIdResult>
@{
    ViewData["Title"] = "Oyuncu Kıyaslama";
}

<style>
    .compare-container {
        padding: 4rem 0;
    }
    .compare-header {
        background: linear-gradient(135deg, rgba(61, 90, 254, 0.1), rgba(244, 247, 246, 0.9));
        border-radius: 40px;
        padding: 3rem;
        margin-bottom: 4rem;
        border: 1px solid var(--border);
    }
    .player-column {
        transition: all 0.3s ease;
    }
    .stat-row {
        background: rgba(255, 255, 255, 0.02);
        border-radius: 12px;
        margin-bottom: 8px;
        padding: 15px;
        border: 1px solid rgba(255,255,255,0.03);
    }
    .stat-name {
        color: var(--text-secondary);
        font-size: 0.85rem;
        font-weight: 700;
        text-transform: uppercase;
        margin-bottom: 5px;
    }
    .stat-value {
        font-size: 1.1rem;
        font-weight: 800;
        color: white;
    }
    .winner-bg {
        background: rgba(61, 90, 254, 0.1) !important;
        border-color: rgba(61, 90, 254, 0.3) !important;
    }
    .winner-text {
        color: var(--accent-color) !important;
    }
    .compare-img {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        border: 3px solid var(--accent-color);
        object-fit: cover;
        margin-bottom: 1.5rem;
        box-shadow: 0 10px 25px rgba(0,0,0,0.3);
    }
</style>

<div class="container compare-container">
    <div class="compare-header text-center">
        <h1 class="display-4 fw-bold mb-4">Veri Tabanlı <span class="text-primary">Kıyaslama</span></h1>
        <div class="d-flex justify-content-center align-items-center gap-4">
            @foreach (var player in Model)
            {
                <div class="text-center">
                    <img src="@(player.ImageUrl ?? "https://eu.ui-avatars.com/api/?name=" + player.FullName)" class="compare-img" alt="@player.FullName">
                    <h5 class="fw-bold mb-0">@player.FullName</h5>
                    <small class="text-secondary">@player.Position</small>
                </div>
                @if (player != Model.Last())
                {
                    <div class="fs-1 fw-900 opacity-25">VS</div>
                }
            }
        </div>
    </div>

    <div class="row g-4">
        <!-- Labels -->
        <div class="col-md-3 d-none d-md-block">
            <div style="margin-top: 150px;">
                <div class="stat-row border-0 bg-transparent"><div class="stat-name">Piyasa Değeri</div></div>
                <div class="stat-row border-0 bg-transparent"><div class="stat-name">Yaş</div></div>
                <div class="stat-row border-0 bg-transparent"><div class="stat-name">Boy / Kilo</div></div>
                <div class="stat-row border-0 bg-transparent"><div class="stat-name">Kulüp</div></div>
                <div class="stat-row border-0 bg-transparent"><div class="stat-name">Tercih Edilen Ayak</div></div>
                <div class="stat-row border-0 bg-transparent"><div class="stat-name">Scouting Kategorisi</div></div>
                <div class="stat-row border-0 bg-transparent"><div class="stat-name">AI Güven Skoru</div></div>
            </div>
        </div>

        <!-- Players Data -->
        @foreach (var player in Model)
        {
            <div class="@(Model.Count == 2 ? "col-md-4" : "col-md-3") player-column">
                <div class="stat-row @(player.MarketValueAmount == Model.Max(m => m.MarketValueAmount) ? "winner-bg" : "")">
                    <div class="stat-name d-md-none">Piyasa Değeri</div>
                    <div class="stat-value @(player.MarketValueAmount == Model.Max(m => m.MarketValueAmount) ? "winner-text" : "")">@player.MarketValue</div>
                </div>
                <div class="stat-row @(player.Age == Model.Min(m => m.Age) ? "winner-bg" : "")">
                    <div class="stat-name d-md-none">Yaş</div>
                    <div class="stat-value">@player.Age Yıl</div>
                </div>
                <div class="stat-row">
                    <div class="stat-name d-md-none">Boy / Kilo</div>
                    <div class="stat-value">@player.Height cm / @player.Weight kg</div>
                </div>
                <div class="stat-row">
                    <div class="stat-name d-md-none">Kulüp</div>
                    <div class="stat-value">@player.ClubName</div>
                </div>
                <div class="stat-row">
                    <div class="stat-name d-md-none">Ayak</div>
                    <div class="stat-value">@player.PreferredFoot</div>
                </div>
                <div class="stat-row">
                    <div class="stat-name d-md-none">Kategori</div>
                    <div class="stat-value text-primary">@player.AiScoutingCategory</div>
                </div>
                <div class="stat-row">
                    <div class="stat-name d-md-none">AI Güven</div>
                    <div class="stat-value">
                        <span class="badge @(player.AiPredictionConfidence == "High" ? "bg-success" : "bg-warning")">@player.AiPredictionConfidence</span>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="text-center mt-5">
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-5">
            <i class="bi bi-arrow-left me-2"></i> Aramaya Dön
        </a>
    </div>
</div>
