@model InterFullMarkt.Domain.Entities.User
@{
    ViewData["Title"] = "Profil Bilgileri";
}

<div class="container py-5">
    <div class="row g-4">
        <!-- Sidebar -->
        <div class="col-lg-3">
            <div class="card bg-white border-0 p-3 rounded-4">
                <partial name="_AccountSidebar" />
            </div>
        </div>

        <!-- Main Content -->
        <div class="col-lg-9">
            <div class="card bg-white border-secondary border-opacity-25 rounded-4 p-4 shadow-lg">
                <h2 class="fw-bold mb-4">Profil Bilgileri</h2>
                
                @if (TempData["Success"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show rounded-3 bg-success bg-opacity-10 text-success border-success border-opacity-25" role="alert">
                        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form asp-action="Profile" method="post" class="row g-4">
                    <div class="col-md-6">
                        <label class="form-label text-secondary small fw-bold">Kullanıcı Adı</label>
                        <input type="text" class="form-control bg-black bg-opacity-25 border-secondary border-opacity-25 text-dark py-2 rounded-3" value="@Model.Username" readonly disabled>
                        <small class="text-muted">Kullanıcı adı değiştirilemez.</small>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small fw-bold">E-Posta Adresi</label>
                        <input type="email" class="form-control bg-black bg-opacity-25 border-secondary border-opacity-25 text-dark py-2 rounded-3" value="@Model.Email" readonly disabled>
                    </div>
                    
                    <div class="col-md-6">
                        <label class="form-label text-secondary small fw-bold">Ad</label>
                        <input type="text" name="firstName" value="@Model.FirstName" class="form-control bg-white border-secondary border-opacity-50 text-dark py-2 rounded-3 shadow-none focus-border-primary" placeholder="Adınız">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-secondary small fw-bold">Soyad</label>
                        <input type="text" name="lastName" value="@Model.LastName" class="form-control bg-white border-secondary border-opacity-50 text-dark py-2 rounded-3 shadow-none focus-border-primary" placeholder="Soyadınız">
                    </div>
                    
                    <div class="col-md-12">
                        <label class="form-label text-secondary small fw-bold">Telefon Numarası</label>
                        <div class="input-group">
                            <span class="input-group-text bg-black bg-opacity-25 border-secondary border-opacity-25 text-secondary">+90</span>
                            <input type="tel" name="phoneNumber" value="@Model.PhoneNumber" class="form-control bg-white border-secondary border-opacity-50 text-dark py-2 rounded-end-3 shadow-none focus-border-primary" placeholder="5xx xxx xxxx">
                        </div>
                    </div>

                    <div class="col-12 pt-3">
                        <button type="submit" class="btn btn-primary rounded-pill px-5 py-2 fw-bold shadow-lg">
                            Değişiklikleri Kaydet
                        </button>
                    </div>
                </form>
            </div>

            <div class="card bg-white bg-opacity-50 border-danger border-opacity-10 rounded-4 p-4 mt-5">
                <h5 class="text-dark fw-bold mb-3"><i class="bi bi-shield-lock text-danger me-2"></i> Hesap Güvenliği</h5>
                <p class="text-secondary small">Şifrenizi yenilemek veya güvenlik ayarlarınızı yönetmek için güvenlik merkezine gidebilirsiniz.</p>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-danger btn-sm rounded-pill px-4">Şifre Değiştir</button>
                    <button class="btn btn-outline-secondary btn-sm rounded-pill px-4">İki Faktörlü Doğrulama</button>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .focus-border-primary:focus {
        border-color: var(--accent-color) !important;
    }
</style>

