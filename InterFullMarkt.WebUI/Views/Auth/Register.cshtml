@{
    ViewData["Title"] = "Kayıt Ol";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-lg-5 col-md-7">
            <div class="card shadow-lg border-0 rounded-4 mt-5 overflow-hidden">
                <div class="card-header bg-success text-dark text-center py-4">
                    <h3 class="font-weight-light mb-0"><i class="bi bi-person-plus-fill me-2"></i> Yeni Hesap Oluştur</h3>
                </div>
                <div class="card-body p-5 bg-light">
                    
                    @if (ViewData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <form asp-controller="Auth" asp-action="Register" method="post">
                        @Html.AntiForgeryToken()
                        
                        <div class="form-floating mb-4">
                            <input type="text" class="form-control rounded-3" id="username" name="username" placeholder="Kullanıcı Adı" required autofocus />
                            <label for="username" class="text-muted"><i class="bi bi-person me-1"></i> Kullanıcı Adı</label>
                        </div>

                        <div class="form-floating mb-4">
                            <input type="email" class="form-control rounded-3" id="email" name="email" placeholder="name@example.com" required />
                            <label for="email" class="text-muted"><i class="bi bi-envelope me-1"></i> E-posta Adresi</label>
                        </div>
                        
                        <div class="form-floating mb-4">
                            <input type="password" class="form-control rounded-3" id="password" name="password" placeholder="Şifre" required />
                            <label for="password" class="text-muted"><i class="bi bi-key me-1"></i> Şifre</label>
                        </div>
                        
                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-success btn-lg rounded-pill shadow-sm fw-bold">
                                Kayıt Ol <i class="bi bi-check-circle ms-1"></i>
                            </button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-4 bg-white border-top-0">
                    <div class="small">
                        <span class="text-muted">Zaten hesabınız var mı?</span> 
                        <a asp-controller="Auth" asp-action="Login" class="text-decoration-none fw-bold ms-1 text-success">Buradan Giriş Yapın!</a>
                    </div>
                </div>
            </div>
            
            <div class="text-center mt-4">
                <p class="text-muted small">Not: Üyelik işlemleri şu an için tanıtım amaçlıdır.</p>
            </div>
        </div>
    </div>
</div>
