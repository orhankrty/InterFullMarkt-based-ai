@{
    ViewData["Title"] = "Hoş Geldiniz";
}

<style>
    .hero-section {
        position: relative;
        min-height: 90vh;
        background: linear-gradient(135deg, rgba(15, 23, 42, 0.95), rgba(16, 185, 129, 0.4)), 
                    url('https://images.unsplash.com/photo-1518605368461-1e12a08f5228?w=1600&q=80') center/cover no-repeat;
        display: flex;
        align-items: center;
        overflow: hidden;
        margin-top: -1rem;
    }

    .hero-content {
        z-index: 2;
        padding: 5rem 0;
    }

    .hero-badge {
        display: inline-block;
        padding: 0.5rem 1.25rem;
        background: rgba(16, 185, 129, 0.2);
        border: 1px solid rgba(16, 185, 129, 0.4);
        border-radius: 50px;
        color: #34d399; /* Lighter emerald for contrast on dark bg */
        font-weight: 700;
        font-size: 0.85rem;
        text-transform: uppercase;
        letter-spacing: 1.5px;
        margin-bottom: 2rem;
        animation: fadeInUp 0.8s ease-out;
    }

    .display-1 {
        font-weight: 900;
        letter-spacing: -2px;
        background: linear-gradient(to right, #ffffff, #e2e8f0);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        margin-bottom: 1.5rem;
        animation: fadeInUp 1s ease-out;
    }

    .lead-text {
        font-size: 1.25rem;
        color: #cbd5e1;
        max-width: 600px;
        margin-bottom: 3rem;
        animation: fadeInUp 1.2s ease-out;
    }

    .cta-group {
        display: flex;
        gap: 1.5rem;
        animation: fadeInUp 1.4s ease-out;
    }

    .btn-hero {
        padding: 1rem 2.5rem;
        border-radius: 50px;
        font-weight: 700;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        font-size: 1.1rem;
    }

    .btn-hero-primary {
        background-color: var(--accent-color);
        color: white;
        box-shadow: 0 10px 25px rgba(16, 185, 129, 0.4);
        border: 1px solid var(--accent-color);
    }

    .btn-hero-outline {
        background: rgba(15, 23, 42, 0.5);
        border: 1px solid rgba(255, 255, 255, 0.2);
        color: #ffffff;
        backdrop-filter: blur(5px);
    }

    .btn-hero:hover {
        transform: translateY(-5px);
    }

    .btn-hero-primary:hover {
        background-color: #059669;
        border-color: #059669;
        color: white;
    }

    .btn-hero-outline:hover {
        background: #ffffff;
        border-color: #ffffff;
        color: #0f172a;
    }

    @@keyframes fadeInUp {
        from { opacity: 0; transform: translateY(30px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* Floating Elements */
    .hero-shapes div {
        position: absolute;
        border-radius: 50%;
        background: linear-gradient(45deg, var(--accent-color), #3b82f6);
        filter: blur(100px);
        opacity: 0.2;
        z-index: 1;
    }

    .shape-1 { width: 400px; height: 400px; top: -100px; right: -100px; }
    .shape-2 { width: 300px; height: 300px; bottom: -50px; left: -100px; }
</style>

<div class="hero-section">
    <div class="hero-shapes">
        <div class="shape-1"></div>
        <div class="shape-2"></div>
    </div>
    
    <div class="container hero-content">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <span class="hero-badge">En Gelişmiş Futbol Platformu</span>
                <h1 class="display-1">Geleceğin Yıldızlarını <br> Bugün Keşfedin.</h1>
                <p class="lead-text">
                    InterFullMarkt ile dünya genelindeki binlerce oyuncuyu, kulübü ve transfer piyasasını en ince detayına kadar takip edin. Veriye dayalı scouting artık parmaklarınızın ucunda.
                </p>
                <div class="cta-group">
                    <a asp-controller="Players" asp-action="Index" class="btn btn-hero btn-hero-primary">
                        <i class="bi bi-search me-2"></i> Keşfetmeye Başla
                    </a>
                    <a asp-controller="News" asp-action="Index" class="btn btn-hero btn-hero-outline">
                        <i class="bi bi-newspaper me-2"></i> Haber Bülteni
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container py-5">
    <div class="row g-4 py-5 text-center align-items-stretch">
        <div class="col-md-4">
            <div class="card p-3 rounded-4 h-100 border-0 shadow-sm" style="border-top: 4px solid var(--accent-color) !important;">
                <div class="card-body d-flex flex-column justify-content-center">
                    <i class="bi bi-graph-up-arrow fs-1 mb-3" style="color: var(--accent-color);"></i>
                    <h4 class="fw-bold">Piyasa Analizi</h4>
                    <p class="text-secondary small mb-0">Oyuncuların değer değişimlerini ve transfer eğilimlerini gerçek zamanlı takip edin.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 rounded-4 h-100 border-0 shadow-sm" style="border-top: 4px solid var(--accent-color) !important;">
                <div class="card-body d-flex flex-column justify-content-center">
                    <i class="bi bi-shield-check fs-1 mb-3" style="color: var(--accent-color);"></i>
                    <h4 class="fw-bold">Resmi Veriler</h4>
                    <p class="text-secondary small mb-0">Kulüpler ve oyuncular hakkında en doğru ve güncel veritabanına erişin.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 rounded-4 h-100 border-0 shadow-sm" style="border-top: 4px solid var(--gold) !important;">
                <div class="card-body d-flex flex-column justify-content-center">
                    <i class="bi bi-lightning-charge fs-1 mb-3" style="color: var(--gold);"></i>
                    <h4 class="fw-bold">Hızlı Erişim</h4>
                    <p class="text-secondary small mb-0">Akıllı arama algoritmalarımız sayesinde aradığınız bilgiye saniyeler içinde ulaşın.</p>
                </div>
            </div>
        </div>
    </div>
</div>
